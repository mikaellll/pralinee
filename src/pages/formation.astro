---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features2 from '~/components/widgets/Features2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Formations Pâtisserie & Boulangerie — Pralinée',
  description:
    'Devenez un expert de la pâtisserie française avec nos formations en ligne. Apprenez les secrets des MOF pour réussir vos croissants, baguettes et éclairs.',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="Nos Formations"
    title="Passez au niveau supérieur en Pâtisserie"
    subtitle="Apprenez les gestes techniques des plus grands chefs pour sublimer vos créations et maîtriser l'art boulanger."
    actions={[{ variant: 'primary', text: 'Voir les programmes', href: '#formations' }]}
    image={{
      src: '~/assets/images/foret-noire.png',
      alt: 'Formation Pâtisserie Pralinée',
    }}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    id="formations"
    title="Nos programmes d'excellence"
    subtitle="Des modules complets pour apprendre à votre rythme, avec des vidéos HD et des fiches techniques détaillées."
    items={[
      {
        title: 'Boulangerie Tradition',
        description: 'Maîtrisez le levain naturel et les farines anciennes pour un pain d’exception.',
        icon: 'tabler:bread',
      },
      {
        title: 'Pâtisserie Fine',
        description: 'Apprenez à monter des entremets complexes et à réaliser des glaçages miroirs parfaits.',
        icon: 'tabler:cake',
      },
      {
        title: 'Viennoiserie Maison',
        description: 'Le secret d’un feuilletage croustillant et d’un alvéolage de rêve pour vos croissants.',
        icon: 'tabler:cookie',
      },
    ]}
  />

  <CallToAction
    title="Prêt à pâtisser ?"
    subtitle="Rejoignez notre communauté de passionnés et commencez votre apprentissage dès maintenant."
    actions={[{ variant: 'primary', text: "S'inscrire à une formation", href: '#' }]}
  />
</Layout>
